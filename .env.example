# ============================================================
# LF ERP Backend v2.0.0 - Variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# Banco de dados (Neon PostgreSQL)
# Obtenha em: https://neon.tech → seu projeto → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua-chave-secreta-jwt-aqui-minimo-32-caracteres

# CORS — URL do frontend (separar múltiplos por vírgula, sem barra no final)
ALLOWED_ORIGINS=https://lf-erp-frontend.vercel.app

# Porta do servidor (Render define automaticamente, não altere em produção)
PORT=3001

# Token para o endpoint /reset-dados (obrigatório para usar o endpoint)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configure também no Render → Environment → RESET_SECRET
RESET_SECRET=sua-chave-secreta-reset-aqui

# Claude AI — Resumo executivo IA (C5.2)
# Obtenha em: https://console.anthropic.com → API Keys
# Configure também no Render → Environment → ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-...

# Sentry — Monitoramento de erros em produção (C5.3)
# Obtenha em: sentry.io → Criar projeto → Node.js → DSN
# Configure também no Render → Environment → SENTRY_DSN
# Opcional: backend funciona sem esta chave, mas erros não serão capturados
SENTRY_DSN=https://...@sentry.io/...

# Token de validação dos webhooks Asaas (boleto/PIX) — OBRIGATÓRIO em produção
# Sem esta chave, os webhooks de pagamento são REJEITADOS (fail-closed por segurança)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configure também no Render → Environment → ASAAS_WEBHOOK_TOKEN
# E no painel do Asaas → Configurações → Webhooks → cabeçalho "asaas-access-token"
ASAAS_WEBHOOK_TOKEN=sua-chave-secreta-webhook-asaas-aqui
