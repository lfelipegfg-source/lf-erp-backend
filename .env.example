# Banco de dados (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=sua-chave-secreta-jwt-aqui

# CORS - URL do frontend (separar múltiplos por vírgula)
ALLOWED_ORIGINS=https://lf-erp-frontend.vercel.app

# Porta do servidor (Render define automaticamente)
PORT=3001

# Token para o endpoint /reset-dados (obrigatório para usar o endpoint)
RESET_SECRET=sua-chave-secreta-reset-aqui
